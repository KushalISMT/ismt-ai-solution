@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Event>

@{
    ViewData["Title"] = "Event Gallery";
}

<style>
    .gallery-card {
        position: relative;
        border-radius: var(--ai-radius);
        overflow: hidden;
        box-shadow: var(--ai-shadow);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        cursor: pointer;
        border: none;
    }

    .gallery-card:hover {
        transform: scale(1.02);
        box-shadow: var(--ai-shadow-hover);
    }

    .gallery-card img {
        width: 100%;
        height: 260px;
        object-fit: cover;
        display: block;
    }

    .gallery-overlay {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        background: linear-gradient(to top, rgba(15, 23, 42, 0.85), transparent);
        color: white;
        padding: 1.5rem 1rem 1rem;
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .gallery-card:hover .gallery-overlay {
        opacity: 1;
    }
</style>

<div class="hero-section text-center">
    <h1 class="display-4 fw-bold mb-3">Event Gallery</h1>
    <p class="lead mb-0">Highlights from our past promotional events, product launches, and industry expos</p>
</div>

@foreach (var item in Model)
{
    <div class="mb-5">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-3">
            <div>
                <h2 class="fw-bold">@item.Title</h2>
                <p class="text-muted mb-0">
                    <i class="bi bi-calendar-event me-1"></i> @item.EventDate.ToString("MMMM dd, yyyy")
                    &nbsp;|&nbsp;
                    <i class="bi bi-geo-alt me-1"></i> @item.Location
                </p>
            </div>
        </div>
        <p class="mb-4">@item.Description</p>

        @if (item.EventImages.Any())
        {
            <div class="row g-3">
                @foreach (var image in item.EventImages)
                {
                    <div class="col-md-6 col-lg-4">
                        <div class="gallery-card" data-bs-toggle="modal" data-bs-target="#imageModal" data-img="@image.ImagePath" data-caption="@image.Caption">
                            <img src="@image.ImagePath" alt="@image.Caption" />
                            <div class="gallery-overlay">
                                <h5 class="mb-1">@image.Caption</h5>
                                <small><i class="bi bi-zoom-in me-1"></i> Click to enlarge</small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 bg-white rounded-4">
                <h4 class="text-muted">No photos available yet</h4>
                <p class="text-muted">Photos from this event will be uploaded soon.</p>
            </div>
        }
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4">
        <h4 class="text-muted">No past events found</h4>
        <p class="text-muted">Check the Upcoming Events page for future events.</p>
    </div>
}

<!-- Image Modal -->
<div class="modal fade" id="imageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="modalCaption">Event Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-0">
                <img id="modalImage" src="" alt="" class="img-fluid rounded-bottom" />
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var imageModal = document.getElementById('imageModal');
        imageModal.addEventListener('show.bs.modal', function (event) {
            var card = event.relatedTarget;
            var imgSrc = card.getAttribute('data-img');
            var caption = card.getAttribute('data-caption');
            document.getElementById('modalImage').src = imgSrc;
            document.getElementById('modalImage').alt = caption;
            document.getElementById('modalCaption').textContent = caption;
        });
    </script>
}
