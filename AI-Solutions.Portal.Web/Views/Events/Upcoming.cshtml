@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Event>

@{
    ViewData["Title"] = "Upcoming Events";
}

<div class="page-header">
    <h1 class="display-5">Upcoming Events</h1>
    <p>Join us at our next promotional events and industry expos.</p>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start mb-3">
                        <div class="feature-icon mb-0 me-3" style="width: 56px; height: 56px; font-size: 1.6rem;">
                            <i class="bi bi-calendar-event"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-1">@item.Title</h5>
                            <p class="text-muted mb-0">
                                <i class="bi bi-calendar3 me-1"></i> @item.EventDate.ToString("MMMM dd, yyyy")
                                <br />
                                <i class="bi bi-geo-alt me-1"></i> @item.Location
                            </p>
                        </div>
                    </div>
                    <p class="card-text text-muted">@item.Description</p>
                </div>
            </div>
        </div>
    }
</div>
