@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Solution>

@{
    ViewData["Title"] = "Our Solutions";
}

<div class="page-header">
    <h1 class="display-5">Our Software Solutions</h1>
    <p>Discover how AI-Solutions empowers industries with intelligent, scalable technology.</p>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="feature-icon mb-0 me-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                            <i class="bi bi-stars"></i>
                        </div>
                        <div>
                            <h5 class="card-title mb-0">@item.Title</h5>
                            <small class="text-muted">@item.Industry</small>
                        </div>
                    </div>
                    <p class="card-text text-muted">@item.Description</p>
                    <p class="card-text"><small class="text-muted"><strong>Technologies:</strong> @item.Technologies</small></p>
                    <a asp-action="Details" asp-route-id="@item.SolutionId" class="btn btn-primary btn-sm">
                        <i class="bi bi-arrow-right me-1"></i> View Details
                    </a>
                </div>
            </div>
        </div>
    }
</div>
