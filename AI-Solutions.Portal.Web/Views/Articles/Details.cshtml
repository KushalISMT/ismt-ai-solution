@model AI_Solutions.Portal.Web.Models.Entities.Article

@{
    ViewData["Title"] = Model.Title;
}

<div class="page-header text-start">
    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @Model.PublishDate.ToString("MMMM dd, yyyy")</small>
    <h1 class="fw-bold mt-2">@Model.Title</h1>
    <p class="text-muted mb-0"><i class="bi bi-person me-1"></i> By @Model.Author</p>
</div>

<div class="card">
    <div class="card-body p-4 p-md-5">
        <p class="lead" style="white-space: pre-line;">@Model.Content</p>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-4">
    <i class="bi bi-arrow-left me-1"></i> Back to Articles
</a>
