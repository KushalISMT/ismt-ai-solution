@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Article>

@{
    ViewData["Title"] = "Articles";
}

<div class="page-header">
    <h1 class="display-5">Articles & Insights</h1>
    <p>News, trends, and thought leadership from AI-Solutions.</p>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100">
                <div class="card-body p-4">
                    <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @item.PublishDate.ToString("MMMM dd, yyyy")</small>
                    <h5 class="card-title mt-2 mb-2">@item.Title</h5>
                    <p class="text-muted mb-3"><i class="bi bi-person me-1"></i> @item.Author</p>
                    <p class="card-text text-muted">@(item.Content.Length > 140 ? item.Content.Substring(0, 140) + "..." : item.Content)</p>
                    <a asp-action="Details" asp-route-id="@item.ArticleId" class="btn btn-primary btn-sm">
                        <i class="bi bi-arrow-right me-1"></i> Read More
                    </a>
                </div>
            </div>
        </div>
    }
</div>
