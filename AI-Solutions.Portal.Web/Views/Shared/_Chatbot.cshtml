@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<div id="ai-chatbot" class="ai-chatbot-widget" data-process-url="@Url.Action("Process", "Chatbot")">
    <button type="button" class="ai-chat-toggle" aria-label="Open chat" aria-expanded="false">
        <i class="bi bi-chat-dots-fill ai-chat-toggle-open"></i>
        <i class="bi bi-x-lg ai-chat-toggle-close"></i>
    </button>

    <div class="ai-chat-window" role="dialog" aria-label="AI-Solutions chatbot">
        <div class="ai-chat-header">
            <div class="ai-chat-title">
                <i class="bi bi-stars"></i>
                <span>AI-Solutions Assistant</span>
            </div>
            <button type="button" class="ai-chat-close" aria-label="Close chat">
                <i class="bi bi-chevron-down"></i>
            </button>
        </div>

        <div class="ai-chat-messages"></div>

        <div class="ai-chat-typing" style="display: none;">
            <span></span><span></span><span></span>
        </div>

        <div class="ai-chat-quick-replies"></div>

        <form class="ai-chat-form">
            <input type="text" class="ai-chat-input" placeholder="Type your message..." autocomplete="off" maxlength="500" />
            <button type="submit" class="ai-chat-send" aria-label="Send">
                <i class="bi bi-send-fill"></i>
            </button>
        </form>
    </div>
</div>

<script src="~/js/chatbot.js" asp-append-version="true"></script>
