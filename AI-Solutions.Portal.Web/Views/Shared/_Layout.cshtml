<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI-Solutions</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AI_Solutions.Portal.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm ai-navbar fixed-top" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-stars me-2"></i>AI-Solutions
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#ai-main-nav" aria-controls="ai-main-nav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="ai-main-nav">
                    @{
                        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
                        string ActiveController(string controller) => currentController == controller ? "active" : "";
                    }
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("Home")" asp-area="" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-1"></i>Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("Solutions")" asp-area="" asp-controller="Solutions" asp-action="Index"><i class="bi bi-grid me-1"></i>Solutions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("CaseStudies")" asp-area="" asp-controller="CaseStudies" asp-action="Index"><i class="bi bi-briefcase me-1"></i>Case Studies</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("Feedback")" asp-area="" asp-controller="Feedback" asp-action="Index"><i class="bi bi-chat-square-heart me-1"></i>Feedback</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("Articles")" asp-area="" asp-controller="Articles" asp-action="Index"><i class="bi bi-journal-text me-1"></i>Articles</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link @ActiveController("Events") dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-calendar-event me-1"></i>Events
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark ai-dropdown">
                                <li><a class="dropdown-item @(currentController == "Events" && currentAction == "Upcoming" ? "active" : "")" asp-area="" asp-controller="Events" asp-action="Upcoming"><i class="bi bi-calendar-check me-1"></i>Upcoming Events</a></li>
                                <li><a class="dropdown-item @(currentController == "Events" && currentAction == "Gallery" ? "active" : "")" asp-area="" asp-controller="Events" asp-action="Gallery"><i class="bi bi-images me-1"></i>Event Gallery</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @ActiveController("Contact")" asp-area="" asp-controller="Contact" asp-action="Index"><i class="bi bi-envelope me-1"></i>Contact Us</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @ActiveController("Admin")" asp-area="" asp-controller="Admin" asp-action="Index"><i class="bi bi-speedometer2 me-1"></i>Admin</a>
                            </li>
                        }
                    </ul>
                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container" style="padding-top: 72px;">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6 text-md-start">
                    <strong class="gradient-text">AI-Solutions</strong>
                    <span class="ms-2">Innovating the future of digital employee experience</span>
                </div>
                <div class="col-md-6 text-md-end mt-2 mt-md-0">
                    <small>&copy; 2026 AI-Solutions. All rights reserved.</small>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @await Html.PartialAsync("_Chatbot")
</body>
</html>
