@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="row justify-content-center text-center">
    <div class="col-md-8">
        <div class="feature-icon mx-auto mb-4" style="width: 90px; height: 90px; font-size: 3rem;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="display-4 fw-bold mb-3">Oops! Something went wrong</h1>
        <p class="lead text-muted mb-4">An unexpected error occurred while processing your request. Please try again later or return to the homepage.</p>
        @if (Model.ShowRequestId)
        {
            <p class="text-muted"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5 mt-3">
            <i class="bi bi-house-door me-2"></i>Return Home
        </a>
    </div>
</div>
