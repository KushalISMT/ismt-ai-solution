@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Feedback>

@{
    ViewData["Title"] = "Manage Feedback";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="fw-bold mb-0">Customer Feedback</h1>
        <p class="text-muted mb-0">Feedback is visible immediately. Use Hide/Show to control visibility.</p>
    </div>
    <a class="btn btn-outline-primary" asp-action="Index">
        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Name</th>
                        <th>Company</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Visibility</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.CreatedDate.ToString("yyyy-MM-dd")</td>
                            <td class="fw-semibold">@item.CustomerName</td>
                            <td>@item.CompanyName</td>
                            <td>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span style="color: @(i <= item.Rating ? "#ffc107" : "#e0e0e0"); font-size: 1rem;">★</span>
                                }
                            </td>
                            <td style="max-width: 360px;">
                                @(string.IsNullOrWhiteSpace(item.Comment) ? "—" : item.Comment)
                            </td>
                            <td>
                                @if (item.IsApproved)
                                {
                                    <span class="badge bg-success">Visible</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hidden</span>
                                }
                            </td>
                            <td class="text-end">
                                <form asp-action="ToggleFeedbackVisibility" asp-route-id="@item.FeedbackId" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(item.IsApproved ? "btn-outline-warning" : "btn-outline-success")">
                                        <i class="bi @(item.IsApproved ? "bi-eye-slash" : "bi-eye") me-1"></i>
                                        @(item.IsApproved ? "Hide" : "Show")
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 bg-white rounded-4 mt-4">
        <h4 class="text-muted">No feedback submitted yet</h4>
        <p class="text-muted">Customer feedback will appear here once submitted.</p>
    </div>
}
