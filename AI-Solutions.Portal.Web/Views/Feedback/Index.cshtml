@model IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Feedback>

@{
    ViewData["Title"] = "Customer Feedback";
    var averageRating = ViewBag.AverageRating as string ?? "0";
}

<div class="hero-section text-center">
    <h1 class="display-4 fw-bold mb-3">What Our Clients Say</h1>
    <p class="lead mb-4">Trusted by industry leaders to deliver AI-powered digital employee experiences</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <span class="badge bg-white text-primary fs-5 px-4 py-2 rounded-pill">
            <i class="bi bi-star-fill me-2"></i> Average Rating: @averageRating / 5
        </span>
        <a asp-action="Submit" class="btn btn-light btn-lg px-4 rounded-pill">
            <i class="bi bi-pencil-square me-2"></i>Leave Feedback
        </a>
    </div>
</div>

<div class="row g-4">
    @foreach (var item in Model)
    {
        var initials = string.Join("", item.CustomerName.Split(' ').Take(2).Select(n => n[0])).ToUpper();
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="feature-icon mb-0 me-3" style="width: 56px; height: 56px; border-radius: 50%;">
                        @initials
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">@item.CustomerName</h5>
                        <small class="text-muted">@item.CompanyName</small>
                    </div>
                </div>

                <div class="mb-3">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= item.Rating)
                        {
                            <span style="color: #ffc107; font-size: 1.2rem;">★</span>
                        }
                        else
                        {
                            <span style="color: #e0e0e0; font-size: 1.2rem;">★</span>
                        }
                    }
                </div>

                <p class="mb-3" style="font-size: 1.05rem; line-height: 1.6; color: #444; font-style: italic;">
                    &ldquo;@item.Comment&rdquo;
                </p>

                <div class="text-muted small mt-auto">
                    <i class="bi bi-calendar3 me-1"></i> @item.CreatedDate.ToString("MMMM dd, yyyy")
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <h4 class="text-muted">No feedback yet</h4>
        <p class="text-muted">Be the first to share your experience with AI-Solutions.</p>
    </div>
}
