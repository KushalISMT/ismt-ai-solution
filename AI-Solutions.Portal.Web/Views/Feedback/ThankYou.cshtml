@{
    ViewData["Title"] = "Thank You";
}

<div class="row justify-content-center">
    <div class="col-lg-8 text-center">
        <div class="card p-5">
            <div class="feature-icon mx-auto mb-4" style="width: 80px; height: 80px; font-size: 2rem;">
                <i class="bi bi-check-lg"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">Thank You!</h1>
            <p class="lead text-muted mb-4">
                Thank you for your feedback. Your rating is now visible on the site.
            </p>
            <a asp-action="Index" class="btn btn-primary btn-lg px-4">
                <i class="bi bi-arrow-left me-2"></i>Back to Feedback
            </a>
        </div>
    </div>
</div>
