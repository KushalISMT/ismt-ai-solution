@{
    ViewData["Title"] = "Home";
    var featuredSolutions = ViewBag.FeaturedSolutions as IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Solution> ?? Enumerable.Empty<AI_Solutions.Portal.Web.Models.Entities.Solution>();
    var latestArticles = ViewBag.LatestArticles as IEnumerable<AI_Solutions.Portal.Web.Models.Entities.Article> ?? Enumerable.Empty<AI_Solutions.Portal.Web.Models.Entities.Article>();
}

<div class="hero-section text-center">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <h1 class="display-3 mb-4">Innovate with AI-Powered Solutions</h1>
            <p class="lead mb-4">
                AI-Solutions helps industries rapidly address digital employee experience challenges through
                intelligent virtual assistants, rapid prototyping, and smart automation.
            </p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a class="btn btn-light btn-lg px-4" asp-controller="Solutions" asp-action="Index">
                    <i class="bi bi-grid me-2"></i>Explore Solutions
                </a>
                <a class="btn btn-outline-light btn-lg px-4" asp-controller="Contact" asp-action="Index">
                    <i class="bi bi-envelope me-2"></i>Get in Touch
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 section-spacing">
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="feature-icon mx-auto">
                <i class="bi bi-robot"></i>
            </div>
            <h4 class="card-title">AI-Powered Assistance</h4>
            <p class="card-text text-muted">Virtual assistants that respond to employee inquiries 24/7 and automate routine tasks.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="feature-icon mx-auto">
                <i class="bi bi-lightning-charge"></i>
            </div>
            <h4 class="card-title">Rapid Prototyping</h4>
            <p class="card-text text-muted">Affordable AI-based prototyping to accelerate design, engineering, and innovation.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div class="feature-icon mx-auto">
                <i class="bi bi-globe"></i>
            </div>
            <h4 class="card-title">Global Reach</h4>
            <p class="card-text text-muted">Supporting people at work across industries worldwide with scalable solutions.</p>
        </div>
    </div>
</div>

<div class="section-spacing">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Featured Solutions</h2>
        <a class="btn btn-outline-primary" asp-controller="Solutions" asp-action="Index">View All</a>
    </div>
    <div class="row g-4">
        @foreach (var solution in featuredSolutions)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="feature-icon mb-0 me-3" style="width: 48px; height: 48px; font-size: 1.4rem;">
                                <i class="bi bi-stars"></i>
                            </div>
                            <h5 class="card-title mb-0">@solution.Title</h5>
                        </div>
                        <p class="card-text text-muted">@solution.Description</p>
                        <a asp-controller="Solutions" asp-action="Details" asp-route-id="@solution.SolutionId" class="btn btn-primary btn-sm">Learn More</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="section-spacing">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Latest Insights</h2>
        <a class="btn btn-outline-primary" asp-controller="Articles" asp-action="Index">View All</a>
    </div>
    <div class="row g-4">
        @foreach (var article in latestArticles)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <small class="text-muted"><i class="bi bi-calendar3 me-1"></i> @article.PublishDate.ToString("MMMM dd, yyyy")</small>
                        <h5 class="card-title mt-2 mb-3">@article.Title</h5>
                        <p class="card-text text-muted">@(article.Content.Length > 100 ? article.Content.Substring(0, 100) + "..." : article.Content)</p>
                        <a asp-controller="Articles" asp-action="Details" asp-route-id="@article.ArticleId" class="btn btn-outline-primary btn-sm">Read More</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
