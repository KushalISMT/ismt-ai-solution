@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="page-header">
    <h1 class="display-5">Privacy Policy</h1>
    <p>Your privacy is important to us. Learn how AI-Solutions handles your information.</p>
</div>

<div class="card">
    <div class="card-body p-4 p-md-5">
        <h4 class="card-title mb-3">Information We Collect</h4>
        <p class="text-muted">We collect information you provide when submitting inquiries through our contact form, including your name, email, phone number, company, country, and job requirements. This helps us respond to your request and improve our services.</p>

        <h4 class="card-title mb-3 mt-4">How We Use Your Data</h4>
        <p class="text-muted">Your data is used solely to communicate with you about your inquiry, provide relevant AI-Solutions services, and analyze customer trends internally. We do not sell your personal information to third parties.</p>

        <h4 class="card-title mb-3 mt-4">Data Security</h4>
        <p class="text-muted mb-0">We implement reasonable security measures to protect your information. However, no method of transmission over the Internet is 100% secure, and we cannot guarantee absolute security.</p>
    </div>
</div>
