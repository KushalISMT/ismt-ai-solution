@{
    ViewData["Title"] = "Thank You";
}

<div class="row justify-content-center">
    <div class="col-md-8 text-center">
        <div class="card p-5">
            <div class="feature-icon mx-auto mb-4" style="width: 80px; height: 80px; font-size: 2.5rem;">
                <i class="bi bi-check-lg"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">Thank You!</h1>
            <p class="lead text-muted mb-4">Your inquiry has been submitted successfully. Our team will review your requirements and contact you soon.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-house-door me-2"></i>Return Home
            </a>
        </div>
    </div>
</div>
